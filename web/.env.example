# Base URL for the API. In dev, leave as /api — Vite proxies it to the API server
# (see API_PROXY_TARGET / vite.config.ts). In production set the full origin, e.g.
# https://api.crumb.app/api
VITE_API_BASE_URL=/api

# Public base URL for uploaded images (the S3 bucket / CDN that serves post photos
# and avatars). Post `imageKey` / user `avatarKey` are appended to this. Leave empty
# to disable remote images (cards fall back to a generated placeholder).
# e.g. https://your-bucket.s3.us-east-1.amazonaws.com
VITE_ASSET_BASE_URL=

# Where the API dev server listens; used only by the Vite dev proxy.
API_PROXY_TARGET=http://localhost:5001

# Mapbox GL access token (public, pk.*). When set, the dashboard renders a real
# recolored Mapbox campus map; leave empty to use the keyless stylized canvas map.
# Get one at https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=
